    1: from __future__ import annotations
       
    1: import json
    1: from pathlib import Path
       
    1: from ..epistemic.web import EpistemicWeb
       
       
    2: class JsonRepository:
    1:     """Loads and saves the epistemic web as JSON files on disk.
       
           data_dir: the project/data/ directory containing entity JSON files.
           """
       
    1:     def __init__(self, data_dir: Path) -> None:
    8:         self._data_dir = data_dir
       
    1:     def load(self) -> EpistemicWeb:
               """Deserialise all entity JSON files and return a fully hydrated EpistemicWeb.
       
