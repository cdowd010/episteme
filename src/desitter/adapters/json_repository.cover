    5:         path = self._data_dir / name
    5:         if not path.exists():
    1:             return []
    4:         return json.loads(path.read_text(encoding="utf-8"))
       
    1:     def _write_file(self, name: str, data: list[dict]) -> None:
               """Write entity data to a JSON file atomically."""
    5:         path = self._data_dir / name
    5:         tmp = path.with_suffix(".json.tmp")
   10:         tmp.write_text(
    5:             json.dumps(data, indent=2, default=str, ensure_ascii=False),
    5:             encoding="utf-8",
               )
    5:         tmp.replace(path)
